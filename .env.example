DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Supabase example:
# DATABASE_URL is the pooled connection string for the running app.
# DIRECT_URL is the direct connection string for Prisma migrations.
# Both values are available from Supabase Project Settings > Database.
